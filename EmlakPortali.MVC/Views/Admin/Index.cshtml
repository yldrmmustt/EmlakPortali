@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var properties = ViewBag.Properties as List<EmlakPortali.MVC.Models.PropertyViewModel> ?? new();
    var users = ViewBag.UserCount as int? ?? 0;
    var activeCount = properties.Count(p => p.IsActive);
    var passiveCount = properties.Count(p => !p.IsActive);
}

<!-- İstatistik Kartları -->
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center bg-success bg-opacity-10"
                     style="width:52px;height:52px;flex-shrink:0;">
                    <i class="bi bi-houses fs-4 text-success"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold">@properties.Count</div>
                    <div class="text-muted small">Toplam İlan</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center bg-primary bg-opacity-10"
                     style="width:52px;height:52px;flex-shrink:0;">
                    <i class="bi bi-check-circle fs-4 text-primary"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-primary">@activeCount</div>
                    <div class="text-muted small">Aktif İlan</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center bg-secondary bg-opacity-10"
                     style="width:52px;height:52px;flex-shrink:0;">
                    <i class="bi bi-pause-circle fs-4 text-secondary"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-secondary">@passiveCount</div>
                    <div class="text-muted small">Pasif İlan</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card stat-card shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3 p-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center bg-warning bg-opacity-10"
                     style="width:52px;height:52px;flex-shrink:0;">
                    <i class="bi bi-people fs-4 text-warning"></i>
                </div>
                <div>
                    <div class="fs-2 fw-bold text-warning">@users</div>
                    <div class="text-muted small">Toplam Kullanıcı</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Son İlanlar Tablosu -->
<div class="card shadow-sm border-0">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h5 class="fw-bold mb-0"><i class="bi bi-list-columns me-2 text-success"></i>Son İlanlar</h5>
        <a href="/Admin/Properties" class="btn btn-sm btn-outline-success">Tümünü Gör</a>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Başlık</th>
                        <th>Fiyat</th>
                        <th>Durum</th>
                        <th>Şehir</th>
                        <th>Sahip</th>
                        <th class="text-end">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in properties.Take(10))
                    {
                        <tr>
                            <td class="text-muted small">#@p.Id</td>
                            <td class="fw-semibold text-truncate" style="max-width:200px;">@p.Title</td>
                            <td class="fw-bold text-success">₺@p.Price.ToString("N0")</td>
                            <td>
                                @if (p.IsActive)
                                {
                                    <span class="badge badge-status-active">Aktif</span>
                                }
                                else
                                {
                                    <span class="badge badge-status-passive">Pasif</span>
                                }
                            </td>
                            <td class="text-muted small">@p.CityName</td>
                            <td class="text-muted small">@p.OwnerName</td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a href="/Property/Details/@p.Id" class="btn btn-sm btn-outline-secondary action-btn" target="_blank">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <form method="post" action="/Admin/TogglePropertyStatus/@p.Id" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm @(p.IsActive ? "btn-outline-warning" : "btn-outline-success") action-btn"
                                                title="@(p.IsActive ? "Pasife Al" : "Aktif Et")">
                                            <i class="bi @(p.IsActive ? "bi-pause" : "bi-play")"></i>
                                        </button>
                                    </form>
                                    <form method="post" action="/Admin/DeleteProperty/@p.Id" class="d-inline"
                                          onsubmit="return confirm('Bu ilanı silmek istediğinize emin misiniz?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger action-btn">
                                            <i class="bi bi-trash3"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
