@model EmlakPortali.MVC.Models.LoginViewModel
@{
    Layout = null;
    ViewData["Title"] = "Yönetici Girişi";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Emlak Portalı Admin</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #1f1f1f 0%, #0d0d0d 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
        }

        .admin-login-card {
            background: rgba(30, 30, 30, 0.95);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 16px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            padding: 3rem;
            width: 100%;
            max-width: 450px;
        }

        .brand-logo {
            font-size: 2.5rem;
            background: linear-gradient(135deg, #D32F2F, #F57C00);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 800;
            text-align: center;
            margin-bottom: 0.5rem;
        }

        .admin-badge {
            display: inline-block;
            background: rgba(211, 47, 47, 0.15);
            color: #ff5252;
            padding: 0.35rem 1rem;
            border-radius: 50px;
            font-size: 0.8rem;
            font-weight: 600;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 2rem;
            border: 1px solid rgba(211, 47, 47, 0.3);
        }

        .form-control {
            background: rgba(0, 0, 0, 0.2);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            padding: 0.8rem 1rem;
            border-radius: 8px;
        }

        .form-control:focus {
            background: rgba(0, 0, 0, 0.4);
            border-color: #D32F2F;
            color: #fff;
            box-shadow: 0 0 0 0.25rem rgba(211, 47, 47, 0.25);
        }

        .form-label {
            color: #aaa;
            font-weight: 500;
            font-size: 0.9rem;
        }

        .btn-admin {
            background: linear-gradient(135deg, #D32F2F, #F57C00);
            border: none;
            color: #fff;
            font-weight: 600;
            padding: 0.8rem;
            border-radius: 8px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(211, 47, 47, 0.3);
        }

        .btn-admin:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(211, 47, 47, 0.5);
            color: #fff;
        }

        .back-link {
            color: #888;
            text-decoration: none;
            font-size: 0.9rem;
            transition: color 0.3s;
        }

        .back-link:hover {
            color: #fff;
        }
    </style>
</head>
<body>

    <div class="admin-login-card text-center">
        <div class="brand-logo"><i class="bi bi-shield-lock-fill"></i> Emlak Portalı</div>
        <div class="admin-badge"><i class="bi bi-gear-fill me-1"></i> Yönetim Paneli</div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger" style="background: rgba(211,47,47,0.1); border: 1px solid rgba(211,47,47,0.3); color: #ff8a80;">
                <i class="bi bi-exclamation-octagon-fill me-2"></i> @ViewBag.Error
            </div>
        }

        <form method="post" asp-controller="Admin" asp-action="Login" class="text-start mt-4">
            <div class="mb-3">
                <label asp-for="Email" class="form-label">E-posta Adresi</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0 text-muted" style="border-color: rgba(255,255,255,0.1);"><i class="bi bi-envelope"></i></span>
                    <input asp-for="Email" class="form-control border-start-0 ps-0" placeholder="admin@emlakportali.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Password" class="form-label">Şifre</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0 text-muted" style="border-color: rgba(255,255,255,0.1);"><i class="bi bi-key"></i></span>
                    <input asp-for="Password" type="password" class="form-control border-start-0 ps-0" placeholder="••••••••" />
                </div>
                <span asp-validation-for="Password" class="text-danger small mt-1 d-block"></span>
            </div>

            <button type="submit" class="btn btn-admin w-100 mb-4">
                <i class="bi bi-box-arrow-in-right me-2"></i> Sisteme Giriş Yap
            </button>
        </form>

        <a asp-controller="Home" asp-action="Index" class="back-link">
            <i class="bi bi-arrow-left me-1"></i> Siteye Dön
        </a>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
