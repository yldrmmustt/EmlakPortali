@model List<EmlakPortali.MVC.Models.PropertyViewModel>
@{
    ViewData["Title"] = "İlanlarım";
    var apiBaseUrl = "http://localhost:5095";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold"><i class="bi bi-houses text-success me-2"></i>İlanlarım</h3>
        <a href="/Property/Create" class="btn btn-success">
            <i class="bi bi-plus-circle me-1"></i> Yeni İlan Ver
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    @if (Model != null && Model.Count > 0)
    {
        <div class="row">
            @foreach (var property in Model)
            {
                var imageUrl = property.ImageUrls != null && property.ImageUrls.Count > 0
                    ? apiBaseUrl + property.ImageUrls[0]
                    : "https://via.placeholder.com/400x200?text=Görsel+Yok";
                var statusBadge = property.IsActive ? "bg-success" : "bg-secondary";
                var statusText = property.IsActive ? "Aktif" : "Pasif";

                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 @(!property.IsActive ? "opacity-75" : "")">
                        <div class="position-relative">
                            <img src="@imageUrl" class="card-img-top" alt="@property.Title" style="height:180px;object-fit:cover;">
                            <span class="position-absolute top-0 start-0 badge @statusBadge m-2">@statusText</span>
                            <span class="position-absolute top-0 end-0 badge bg-warning text-dark m-2">@property.Status</span>
                        </div>
                        <div class="card-body">
                            <h5 class="text-success fw-bold mb-1">₺@property.Price.ToString("N0")</h5>
                            <h6 class="card-title text-truncate fw-semibold" title="@property.Title">@property.Title</h6>
                            <p class="card-text text-muted small mb-2">
                                <i class="bi bi-geo-alt-fill text-danger"></i> @property.CityName / @property.DistrictName
                            </p>
                            <div class="d-flex text-muted small">
                                <span class="me-3"><i class="bi bi-door-open"></i> @property.RoomCount</span>
                                <span class="me-3"><i class="bi bi-aspect-ratio"></i> @property.GrossSquareMeters m²</span>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent border-0 p-3 pt-0">
                            <div class="d-flex gap-2">
                                <a href="/Property/Details/@property.Id" class="btn btn-sm btn-outline-success flex-fill">
                                    <i class="bi bi-eye"></i> Görüntüle
                                </a>
                                <a href="/Property/Edit/@property.Id" class="btn btn-sm btn-outline-warning flex-fill">
                                    <i class="bi bi-pencil"></i> Düzenle
                                </a>
                                <form method="post" action="/Property/Delete/@property.Id"
                                      onsubmit="return confirm('Bu ilanı silmek istediğinize emin misiniz?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash3"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body text-center py-5">
                <i class="bi bi-house-x text-muted" style="font-size:4rem;"></i>
                <h5 class="text-muted mt-3">Henüz hiç ilanınız yok</h5>
                <p class="text-muted">İlk ilanınızı vererek başlayın!</p>
                <a href="/Property/Create" class="btn btn-success btn-lg">
                    <i class="bi bi-plus-circle me-1"></i> İlan Ver
                </a>
            </div>
        </div>
    }
</div>
