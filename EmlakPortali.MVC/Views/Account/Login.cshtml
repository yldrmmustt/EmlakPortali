@model EmlakPortali.MVC.Models.LoginViewModel
@{
    ViewData["Title"] = "Giriş Yap - Emlak Portalı";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white text-center py-4">
                    <h2 class="mb-0 fw-bold">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Giriş Yap
                    </h2>
                </div>
                <div class="card-body p-5">

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                    }

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@error.ErrorMessage</div>
                            }
                        </div>
                    }

                    <form asp-action="Login" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold">E-posta Adresi</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="ornek@email.com" required />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-bold">Şifre</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" required />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-success w-100 fw-bold py-2">
                            <i class="bi bi-box-arrow-in-right me-2"></i>Giriş Yap
                        </button>
                    </form>

                    <hr class="border-success border-opacity-25 my-4" />

                    <div class="text-center">
                        <p class="text-muted mb-0">Hesabınız yok mu?</p>
                        <a href="/Account/Register" class="btn btn-outline-success btn-sm mt-2">
                            <i class="bi bi-person-plus-fill me-1"></i>Kayıt Ol
                        </a>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 mt-3">
                <div class="card-body">
                    <h6 class="fw-bold text-success mb-3">
                        <i class="bi bi-info-circle me-2"></i>Bilgi
                    </h6>
                    <ul class="list-unstyled small text-muted">
                        <li><i class="bi bi-check-circle text-success me-2"></i>Güvenli giriş</li>
                        <li><i class="bi bi-check-circle text-success me-2"></i>Hızlı ve kolay</li>
                        <li><i class="bi bi-check-circle text-success me-2"></i>İlan yayınla ve yönet</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
