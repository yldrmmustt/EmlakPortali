@model EmlakPortali.MVC.Models.RegisterViewModel
@{
    ViewData["Title"] = "Kayıt Ol - Emlak Portalı";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white text-center py-4">
                    <h2 class="mb-0 fw-bold">
                        <i class="bi bi-person-plus-fill me-2"></i>Hesap Oluştur
                    </h2>
                </div>
                <div class="card-body p-5">

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div>@error.ErrorMessage</div>
                            }
                        </div>
                    }

                    <form asp-action="Register" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="FirstName" class="form-label fw-bold">Ad</label>
                                <input asp-for="FirstName" type="text" class="form-control" placeholder="Ahmet" required />
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="LastName" class="form-label fw-bold">Soyad</label>
                                <input asp-for="LastName" type="text" class="form-control" placeholder="Yıldız" required />
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold">E-posta Adresi</label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="ornek@email.com" required />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-bold">Şifre</label>
                            <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" required />
                            <small class="text-muted d-block mt-2">
                                <i class="bi bi-info-circle me-1"></i>
                                Min. 8 karakter, Büyük Harf, Küçük Harf, Sayı ve Özel Karakter
                            </small>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input type="checkbox" class="form-check-input" id="termsCheck" required />
                            <label class="form-check-label" for="termsCheck">
                                <a href="#" class="text-success text-decoration-none">Hizmet Şartlarını</a> ve
                                <a href="#" class="text-success text-decoration-none">Gizlilik Politikasını</a> kabul ediyorum.
                            </label>
                        </div>

                        <button type="submit" class="btn btn-success w-100 fw-bold py-2">
                            <i class="bi bi-person-plus-fill me-2"></i>Kayıt Ol
                        </button>
                    </form>

                    <hr class="border-success border-opacity-25 my-4" />

                    <div class="text-center">
                        <p class="text-muted mb-0">Zaten hesabınız var mı?</p>
                        <a href="/Account/Login" class="btn btn-outline-success btn-sm mt-2">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Giriş Yap
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
