@{
    ViewData["Title"] = "İlan Ver";
    var cities = ViewBag.Cities as List<EmlakPortali.MVC.Models.CityViewModel> ?? new List<EmlakPortali.MVC.Models.CityViewModel>();
    var categories = ViewBag.Categories as List<EmlakPortali.MVC.Models.CategoryViewModel> ?? new List<EmlakPortali.MVC.Models.CategoryViewModel>();
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white p-4">
                    <h3 class="mb-0"><i class="bi bi-house-add me-2"></i>Yeni İlan Ekle</h3>
                </div>
                <div class="card-body p-4">

                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                    }

                    <form asp-controller="Property" asp-action="Create" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-bold">İlan Başlığı</label>
                            <input type="text" name="Title" class="form-control" required placeholder="Örn: Denize Sıfır Sahibinden 3+1 Lüks Daire">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Açıklama</label>
                            <textarea name="Description" class="form-control" rows="4" required></textarea>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Fiyat (₺)</label>
                                <input type="number" name="Price" class="form-control" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Durum</label>
                                <select name="Status" class="form-select" required>
                                    <option value="Satılık">Satılık</option>
                                    <option value="Kiralık">Kiralık</option>
                                    <option value="Günlük Kiralık">Günlük Kiralık</option>
                                </select>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Kategori</label>
                                <select name="CategoryId" class="form-select" required>
                                    <option value="">Seçiniz</option>
                                    @foreach (var cat in categories)
                                    {
                                        <option value="@cat.Id">@cat.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Şehir</label>
                                <select name="CityId" id="CityId" class="form-select" required>
                                    <option value="">Seçiniz</option>
                                    @foreach (var city in cities)
                                    {
                                        <option value="@city.Id">@city.Name</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold">İlçe</label>
                                <select name="DistrictId" id="DistrictId" class="form-select" required>
                                    <option value="">Önce Şehir Seçin</option>
                                </select>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-3">
                                <label class="form-label fw-bold">Oda Sayısı</label>
                                <input type="text" name="RoomCount" class="form-control" placeholder="3+1" required>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-bold">Brüt m²</label>
                                <input type="number" name="GrossSquareMeters" class="form-control" required>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-bold">Net m²</label>
                                <input type="number" name="NetSquareMeters" class="form-control" required>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label fw-bold">Bina Yaşı</label>
                                <input type="number" name="BuildingAge" class="form-control" required>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-4">
                                <label class="form-label fw-bold">Isıtma Tipi</label>
                                <input type="text" name="HeatingType" class="form-control" placeholder="Kombi (Doğalgaz)" required>
                            </div>
                            <div class="col-md-2 mt-4 pt-2">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="HasBalcony" id="HasBalcony" value="true">
                                    <label class="form-check-label" for="HasBalcony">Balkon</label>
                                </div>
                            </div>
                            <div class="col-md-2 mt-4 pt-2">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="HasElevator" id="HasElevator" value="true">
                                    <label class="form-check-label" for="HasElevator">Asansör</label>
                                </div>
                            </div>
                            <div class="col-md-2 mt-4 pt-2">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" name="IsFurnished" id="IsFurnished" value="true">
                                    <label class="form-check-label" for="IsFurnished">Eşyalı</label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold border-bottom w-100 pb-2"><i class="bi bi-images"></i> Emlak Fotoğrafları</label>
                            <input type="file" name="images" class="form-control form-control-lg" multiple accept="image/*">
                            <small class="text-muted">Birden fazla resim seçebilirsiniz. İlk seçilen resim kapak resmi olacaktır.</small>
                        </div>

                        <button type="submit" class="btn btn-success btn-lg w-100 fw-bold">
                            <i class="bi bi-check2-circle me-2"></i>İlanı Yayınla
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Şehir değişince ilçeleri yükle (MVC proxy üzerinden)
        $("#CityId").change(function () {
            var cityId = $(this).val();
            $("#DistrictId").empty().append('<option value="">Seçiniz</option>');
            if (cityId) {
                $.get('/Property/GetDistricts?cityId=' + cityId, function (districts) {
                    districts.forEach(function (d) {
                        $("#DistrictId").append('<option value="' + d.id + '">' + d.name + '</option>');
                    });
                });
            }
        });
    </script>
}
