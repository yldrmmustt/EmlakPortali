@{
    ViewData["Title"] = "Hakkında - Emlak Portalı";
}

<!-- Hero Section -->
<div class="hero-section mb-5">
    <div class="container py-5">
        <h1 class="display-4 fw-bold mb-3">Hakkında Emlak Portalı</h1>
        <p class="lead mb-0">Türkiye'nin en güvenilir ve modern emlak platformu</p>
    </div>
</div>

<div class="container mb-5">
    <div class="row g-5">
        <!-- About Content -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h2 class="fw-bold mb-3">
                        <i class="bi bi-building me-2 text-success"></i>Misyonumuz
                    </h2>
                    <p class="lead text-muted">
                        Emlak Portalı, gayrimenkul piyasasını daha şeffaf, güvenli ve erişilebilir hale getirmek için kurulmuştur.
                        Kullanıcılarımızın hayallerindeki evi, ofisi veya yatırımını bulmaları için en iyi platform olmayı hedefliyoruz.
                    </p>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h2 class="fw-bold mb-3">
                        <i class="bi bi-lightbulb me-2 text-success"></i>Vizyonumuz
                    </h2>
                    <p class="text-muted">
                        Her kullanıcı için kişiselleştirilmiş, güvenilir ve kullanımı kolay bir emlak platformu sunmak.
                        Teknoloji ve insan dokunuşunun mükemmel birleşimiyle emlak işlemlerini basitleştirmek.
                    </p>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <h2 class="fw-bold mb-3">
                        <i class="bi bi-shield-check me-2 text-success"></i>Neden Biz?
                    </h2>
                    <ul class="list-unstyled">
                        <li class="mb-3">
                            <i class="bi bi-check-circle text-success me-2"></i>
                            <strong>Güvenli İşlemler</strong> - Tüm verileriniz şifrelenerek korunur
                        </li>
                        <li class="mb-3">
                            <i class="bi bi-check-circle text-success me-2"></i>
                            <strong>Doğrulanmış İlanlar</strong> - Her ilan incelenir ve onaylanır
                        </li>
                        <li class="mb-3">
                            <i class="bi bi-check-circle text-success me-2"></i>
                            <strong>7/24 Destek</strong> - Sorunlarınız için her zaman buradayız
                        </li>
                        <li class="mb-3">
                            <i class="bi bi-check-circle text-success me-2"></i>
                            <strong>Kolay Kullanım</strong> - Modern ve sezgisel arayüz tasarımı
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Side Info -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 bg-light mb-4">
                <div class="card-body text-center">
                    <h3 class="fw-bold text-success mb-4">Rakamlarla Biz</h3>
                    <div class="mb-4">
                        <h2 class="fw-bold text-success">50K+</h2>
                        <p class="text-muted">Aktif İlan</p>
                    </div>
                    <div class="mb-4">
                        <h2 class="fw-bold text-success">150K+</h2>
                        <p class="text-muted">Kayıtlı Kullanıcı</p>
                    </div>
                    <div>
                        <h2 class="fw-bold text-success">2023</h2>
                        <p class="text-muted">Kuruluş Yılı</p>
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white border-bottom border-success border-opacity-25">
                    <h5 class="mb-0 fw-bold">İletişim Bilgileri</h5>
                </div>
                <div class="card-body">
                    <p class="mb-3">
                        <i class="bi bi-envelope text-success me-2"></i>
                        <a href="mailto:info@emlakportali.com" class="text-success text-decoration-none">
                            info@emlakportali.com
                        </a>
                    </p>
                    <p class="mb-3">
                        <i class="bi bi-telephone text-success me-2"></i>
                        <a href="tel:+90212123456" class="text-success text-decoration-none">
                            +90 (212) 123-4567
                        </a>
                    </p>
                    <p>
                        <i class="bi bi-geo-alt text-success me-2"></i>
                        Emlak Portalı, İstanbul, TR
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
