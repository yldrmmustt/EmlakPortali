@model ErrorViewModel
@{
    ViewData["Title"] = "Hata Oluştu";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="mb-5">
                <i class="bi bi-exclamation-triangle text-danger" style="font-size: 4rem; display: block; margin-bottom: 20px;"></i>
                <h1 class="fw-bold text-danger mb-3">Bir Hata Oluştu!</h1>
                <p class="lead text-muted">Üzgünüz, sayfayı yüklerken bir sorun yaşandı.</p>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body">
                    <p class="text-muted mb-3">
                        <i class="bi bi-info-circle me-2"></i>
                        Bu hata yazılımcılara bildirilmiştir. Lütfen bir kaç dakika sonra tekrar deneyiniz.
                    </p>

                    @if (Model != null && Model.ShowRequestId)
                    {
                        <p class="small text-muted">
                            <strong>İstek ID:</strong> <code>@Model.RequestId</code>
                        </p>
                    }
                </div>
            </div>

            <a href="/" class="btn btn-success btn-lg me-2">
                <i class="bi bi-house-door me-2"></i>Anasayfaya Dön
            </a>
            <a href="javascript:history.back()" class="btn btn-outline-success btn-lg">
                <i class="bi bi-arrow-left me-2"></i>Geri Dön
            </a>
        </div>
    </div>
</div>
