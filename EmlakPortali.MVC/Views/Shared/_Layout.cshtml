<!DOCTYPE html>
<html lang="tr" id="htmlElement" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Emlak Portalı</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Custom Theme CSS -->
    <link rel="stylesheet" href="~/css/theme.css" asp-append-version="true" />
</head>
<body id="appBody" class="theme-light">
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-light border-bottom border-success border-opacity-25 sticky-top bg-light">
        <div class="container-fluid px-4">
            <!-- Logo -->
            <a class="navbar-brand fw-bold text-success" asp-controller="Home" asp-action="Index">
                <i class="bi bi-building fs-5 me-2"></i>
                <span class="d-none d-md-inline">Emlak Portalı</span>
            </a>

            <!-- Hamburger -->
            <button class="navbar-toggler border-success" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <!-- Nav Items -->
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-lg-center">
                    <li class="nav-item">
                        <a class="nav-link" href="/">
                            <i class="bi bi-house-door-fill me-1"></i> Anasayfa
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Property">
                            <i class="bi bi-building me-1"></i> İlanlar
                        </a>
                    </li>

                    <!-- Dark Mode Toggle -->
                    <li class="nav-item ms-lg-3">
                        <button class="btn btn-sm btn-outline-success" id="themeToggle" title="Tema Değiştir">
                            <i class="bi bi-moon-fill"></i>
                        </button>
                    </li>

                    <!-- Auth Menu — Razor/Session tabanlı -->
                    @{
                        var jwtToken = Context.Session.GetString("JWTToken");
                        var userName = Context.Session.GetString("UserName");
                        var userRole = Context.Session.GetString("UserRole");
                        bool isLoggedIn = !string.IsNullOrEmpty(jwtToken);
                    }

                    @if (isLoggedIn)
                    {
                        <li class="nav-item me-2">
                            <a class="btn btn-success btn-sm" href="/Property/Create">
                                <i class="bi bi-plus-circle me-1"></i> İlan Ver
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle fw-bold" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>@userName
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                @if (userRole == "Admin")
                                {
                                    <li>
                                        <a class="dropdown-item fw-bold text-success" href="/Admin/Index">
                                            <i class="bi bi-speedometer2 me-2"></i>Yönetim Paneli
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                }
                                <li>
                                    <a class="dropdown-item" href="/Account/Profile">
                                        <i class="bi bi-person me-2"></i>Profilim
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/Account/MyProperties">
                                        <i class="bi bi-house me-2"></i>İlanlarım
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/Account/Favorites">
                                        <i class="bi bi-bookmark me-2"></i>Favorilerim
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item text-danger" href="/Account/Logout">
                                        <i class="bi bi-box-arrow-right me-2"></i>Çıkış Yap
                                    </a>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Account/Login">Giriş Yap</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-success btn-sm ms-2" href="/Account/Register">Kayıt Ol</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="min-vh-100 py-4">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-light border-top border-success border-opacity-25 mt-5 py-5">
        <div class="container">
            <div class="row mb-4">
                <div class="col-md-4 mb-4">
                    <h5 class="text-success fw-bold mb-3">
                        <i class="bi bi-building me-2"></i>Emlak Portalı
                    </h5>
                    <p class="text-muted small">
                        Türkiye'nin en güvenilir emlak platformu.
                        Ev, arsa, villa ve daha pek çok gayrimenkul ilanı.
                    </p>
                </div>

                <div class="col-md-4 mb-4">
                    <h6 class="text-dark fw-bold mb-3">Hızlı Linkler</h6>
                    <ul class="list-unstyled">
                        <li><a href="/" class="text-success text-decoration-none small">Anasayfa</a></li>
                        <li><a href="/Property" class="text-success text-decoration-none small">İlanlar</a></li>
                        <li><a href="#" class="text-success text-decoration-none small">Hakkında</a></li>
                        <li><a href="#" class="text-success text-decoration-none small">İletişim</a></li>
                    </ul>
                </div>

                <div class="col-md-4 mb-4">
                    <h6 class="text-dark fw-bold mb-3">İletişim</h6>
                    <p class="text-muted small mb-1">
                        <i class="bi bi-envelope me-2"></i>
                        info@emlakportali.com
                    </p>
                    <p class="text-muted small">
                        <i class="bi bi-telephone me-2"></i>
                        +90 (212) 123-4567
                    </p>
                </div>
            </div>

            <hr class="border-success border-opacity-25">
            <div class="text-center text-muted small">
                <p>&copy; 2024 Emlak Portalı. Tüm hakları saklıdır.</p>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <!-- AJAX Helper -->
    <script src="~/js/ajax-helper.js"></script>
    <!-- Theme JS -->
    <script src="~/js/theme.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
