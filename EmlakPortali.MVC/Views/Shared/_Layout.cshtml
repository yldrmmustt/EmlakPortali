<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Emlak Portalı</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EmlakPortali.MVC.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-4 py-3">
            <div class="container">
                <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-houses-fill"></i> Emlak Portalı
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav" id="authMenu">
                        <!-- JS ile doldurulacak -->
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container pb-5">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted mt-auto">
        <div class="container text-center py-3">
            &copy; 2026 - EmlakPortali - "Clean Code & SOLID"
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function() {
            function updateNav() {
                const token = localStorage.getItem("token");
                const user = JSON.parse(localStorage.getItem("user"));
                
                if (token && user) {
                    let adminMenuHtml = "";
                    try {
                        const base64Url = token.split('.')[1];
                        const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                        const jsonPayload = decodeURIComponent(atob(base64).split('').map(function(c) {
                            return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                        }).join(''));
                        const decoded = JSON.parse(jsonPayload);
                        const roleKey = Object.keys(decoded).find(k => k.includes('role'));
                        
                        if(decoded && decoded[roleKey] === 'Admin') {
                            adminMenuHtml = `
                                <li>
                                    <a class="dropdown-item fw-bold text-primary" href="/Admin/Index"><i class="bi bi-speedometer2"></i> Yönetim Paneli</a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                            `;
                        }
                    } catch (err) { }

                    $("#authMenu").html(`
                        <li class="nav-item me-2">
                            <a class="btn btn-primary" href="/Property/Create"><i class="bi bi-plus-circle"></i> İlan Ver</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark fw-bold" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle"></i> ${user.firstName} ${user.lastName}
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                ${adminMenuHtml}
                                <li><a class="dropdown-item text-muted" href="#" onclick="alert('Profil sayfası yapım aşamasındadır.');">Profilim (Yakında)</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" href="#" id="logoutBtn">Çıkış Yap</a></li>
                            </ul>
                        </li>
                    `);
                } else {
                    $("#authMenu").html(`
                        <li class="nav-item">
                            <a class="nav-link text-dark" href="/Account/Login">Giriş Yap</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-primary ms-2" href="/Account/Register">Kayıt Ol</a>
                        </li>
                    `);
                }
            }

            updateNav();

            $(document).on("click", "#logoutBtn", function(e) {
                e.preventDefault();
                localStorage.removeItem("token");
                localStorage.removeItem("user");
                window.location.href = "/";
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
