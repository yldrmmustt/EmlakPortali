<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Yönetim Paneli - Emlak Portalı</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body { background-color: #f0f2f5; font-family: 'Segoe UI', sans-serif; }
        .sidebar {
            min-height: 100vh;
            width: 260px;
            background: linear-gradient(180deg, #1B3A2A 0%, #2D6A4F 100%);
            color: white;
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0; left: 0; bottom: 0;
            z-index: 1000;
            box-shadow: 4px 0 15px rgba(0,0,0,0.15);
        }
        .sidebar-brand {
            padding: 1.5rem 1.25rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            font-size: 1.2rem;
            font-weight: 700;
            letter-spacing: 0.5px;
        }
        .sidebar-nav { padding: 1rem 0.75rem; flex: 1; }
        .sidebar .nav-link {
            color: rgba(255,255,255,0.75);
            border-radius: 8px;
            padding: 0.65rem 1rem;
            margin-bottom: 2px;
            transition: all 0.2s;
            font-size: 0.9rem;
        }
        .sidebar .nav-link:hover { color: white; background: rgba(255,255,255,0.1); }
        .sidebar .nav-link.active { color: white; background: rgba(255,255,255,0.2); font-weight: 600; }
        .sidebar .nav-section { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px; color: rgba(255,255,255,0.4); padding: 1rem 1rem 0.25rem; }
        .sidebar-footer {
            padding: 1rem 1.25rem;
            border-top: 1px solid rgba(255,255,255,0.1);
            background: rgba(0,0,0,0.15);
        }
        .main-wrapper { margin-left: 260px; min-height: 100vh; }
        .top-bar {
            background: white;
            border-bottom: 1px solid #e5e7eb;
            padding: 0.85rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }
        .main-content { padding: 1.5rem; }
        .stat-card { border-radius: 12px; border: none; transition: transform 0.2s; }
        .stat-card:hover { transform: translateY(-2px); }
        .badge-status-active { background-color: #d1fae5; color: #065f46; }
        .badge-status-passive { background-color: #f3f4f6; color: #6b7280; }
        .badge-admin { background-color: #fef3c7; color: #92400e; }
        .badge-user { background-color: #dbeafe; color: #1e40af; }
        .action-btn { border-radius: 6px; font-size: 0.8rem; padding: 0.3rem 0.75rem; }
        table tbody tr:hover { background-color: #f9fafb; }
    </style>
</head>
<body>
    @{
        var adminName = Context.Session.GetString("UserName") ?? "Admin";
        var adminEmail = Context.Session.GetString("UserEmail") ?? "";
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    }

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-brand">
            <a href="/" class="text-white text-decoration-none">
                <i class="bi bi-buildings me-2"></i>Emlak Portalı
            </a>
        </div>

        <div class="sidebar-nav">
            <div class="nav-section">Genel</div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a href="/Admin/Index" class="nav-link @(currentAction == "Index" ? "active" : "")">
                        <i class="bi bi-speedometer2 me-2"></i>Dashboard
                    </a>
                </li>
            </ul>

            <div class="nav-section mt-2">Yönetim</div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a href="/Admin/Properties" class="nav-link @(currentAction == "Properties" ? "active" : "")">
                        <i class="bi bi-houses me-2"></i>İlanlar
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/Admin/Users" class="nav-link @(currentAction == "Users" ? "active" : "")">
                        <i class="bi bi-people-fill me-2"></i>Kullanıcılar
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/Admin/Categories" class="nav-link @(currentAction == "Categories" ? "active" : "")">
                        <i class="bi bi-tag-fill me-2"></i>Kategoriler
                    </a>
                </li>
            </ul>

            <div class="nav-section mt-2">Sistem</div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a href="/" class="nav-link">
                        <i class="bi bi-house-door me-2"></i>Siteye Dön
                    </a>
                </li>
            </ul>
        </div>

        <div class="sidebar-footer">
            <div class="d-flex align-items-center gap-2">
                <div class="rounded-circle bg-success d-flex align-items-center justify-content-center text-white fw-bold"
                     style="width:38px;height:38px;font-size:1rem;flex-shrink:0;">
                    @(adminName.Length > 0 ? adminName[0].ToString().ToUpper() : "A")
                </div>
                <div class="overflow-hidden">
                    <div class="fw-semibold text-white text-truncate" style="font-size:0.85rem;">@adminName</div>
                    <a href="/Account/Logout" class="text-danger text-decoration-none" style="font-size:0.75rem;">
                        <i class="bi bi-box-arrow-right me-1"></i>Çıkış Yap
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Main -->
    <div class="main-wrapper">
        <div class="top-bar">
            <div class="fw-semibold text-secondary">
                <i class="bi bi-shield-check text-success me-1"></i>
                Yönetim Paneli
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="badge bg-success">Admin</span>
                <span class="text-muted small">@adminEmail</span>
            </div>
        </div>

        <div class="main-content">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
